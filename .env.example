# ============================================================
# SentinelHive — Environment Variables (Template)
# Copy to .env and fill in actual values. .env is git-ignored.
# ============================================================

# Project metadata
PROJECT_NAME=sentinelhive
TZ=UTC

# Cowrie configuration
COWRIE_HOSTNAME=svr01
COWRIE_SSH_PORT=2222
COWRIE_TELNET_PORT=2223

# Elasticsearch (Phase 2)
ELASTIC_VERSION=8.13.0
ELASTIC_PASSWORD=changeme_in_real_env
ES_JAVA_OPTS=-Xms1g -Xmx1g

# Kibana (Phase 2)
KIBANA_PORT=5601

# Logstash (Phase 2)
LOGSTASH_PORT=5044
